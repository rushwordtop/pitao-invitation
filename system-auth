<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>您有一則未讀訊息</title>
    <meta property="og:title" content="系統安全通知">
    <meta property="og:description" content="您收到一則加密訊息，請點擊進行身分驗證。">
    <meta property="og:image" content="https://img.icons8.com/color/96/lock-landscape.png">
    
    <style>
        :root { --primary: #ff69b4; --bg: #ffe4e1; --text: #444; }
        body { margin: 0; padding: 0; display: flex; justify-content: center; align-items: center; min-height: 100vh; background: var(--bg); font-family: 'Microsoft JhengHei', sans-serif; overflow: hidden; }
        
        #envoy { position: fixed; z-index: 200; transition: all 2.5s ease-in-out; pointer-events: none; }
        #envoy img { width: 140px; filter: drop-shadow(2px 2px 5px rgba(0,0,0,0.1)); }

        .card { display: none; background: white; padding: 30px; border-radius: 25px; box-shadow: 0 15px 40px rgba(0,0,0,0.15); text-align: center; width: 85%; max-width: 380px; z-index: 100; border: 2px solid #fff; }
        h2 { color: var(--primary); margin-bottom: 15px; font-size: 1.4rem; }
        p { color: var(--text); line-height: 1.6; margin-bottom: 25px; }

        #envelope { width: 150px; height: 110px; background: var(--primary); display: flex; justify-content: center; align-items: center; border-radius: 15px; cursor: pointer; animation: float 2s infinite ease-in-out; }
        #envelope::after { content: "📩"; font-size: 50px; }
        @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }

        .btn { padding: 15px 25px; border: none; border-radius: 50px; cursor: pointer; font-weight: bold; transition: 0.3s; margin: 10px; font-size: 1rem; width: 80%; }
        .btn-yes { background: var(--primary); color: white; }
        .btn-no { background: #eee; color: #888; }
        
        #loading { display: none; color: var(--primary); font-weight: bold; margin-top: 15px; }
    </style>
</head>
<body>

    <div id="envoy"><img src="Me.PNG"></div>
    <audio id="bgm1" loop src="Upbeat%20Ukul.mp3"></audio>
    <audio id="bgm2" loop src="Acoustic%20Guitar.mp3"></audio>

    <div id="envelope" onclick="start()"></div>

    <div id="step1" class="card">
        <h2>星彤你好！🌟</h2>
        <p>我是特派使者小秋。<br>阿秋說今天星期一了，<br>要我過來找妳拿回覆。<br><br><b>5/22 (五) 的家庭日活動</b></p>
        <button class="btn btn-yes" onclick="showChoice()">準備好了，點我回覆</button>
    </div>

    <div id="step2" class="card">
        <h2>最後決定 ✉️</h2>
        <p>請勾選你的意願：</p>
        
        <form id="hidden-form" action="https://formsubmit.co/a911097@gmail.com" method="POST">
            <input type="hidden" name="_next" value="https://rushwordtop.github.io/pitao-invitation/">
            <input type="hidden" name="_subject" value="特派員小秋回報：星彤的決定！">
            <input type="hidden" name="_captcha" value="false">
            
            <input type="hidden" name="星彤的回覆" id="reply-value">
            
            <button type="button" class="btn btn-yes" onclick="submitReply('我要去！🙋‍♀️')">我會準時參加！</button>
            <button type="button" class="btn btn-no" onclick="submitReply('我不能去 😭')">那天沒辦法去...</button>
        </form>
        
        <div id="loading">正在將回覆交給小秋... 🚀</div>
    </div>

    <script>
        const bgm1 = document.getElementById('bgm1');
        const bgm2 = document.getElementById('bgm2');
        const envoy = document.getElementById('envoy');

        function moveEnvoy() {
            const x = Math.max(10, Math.random() * (window.innerWidth - 150));
            const y = Math.max(10, Math.random() * (window.innerHeight - 150));
            envoy.style.left = x + 'px'; envoy.style.top = y + 'px';
        }
        setInterval(moveEnvoy, 2500); moveEnvoy();

        function start() { bgm1.play().catch(e=>{}); show('step1'); }
        function showChoice() { show('step2'); }
        function show(id) { 
            document.querySelectorAll('.card, #envelope').forEach(c => c.style.display = 'none');
            document.getElementById(id).style.display = 'block'; 
        }

        function submitReply(choice) {
            document.getElementById('loading').style.display = 'block';
            document.getElementById('reply-value').value = choice;
            
            if (choice.includes('要去')) {
                bgm1.pause();
                bgm2.play().catch(e=>{});
            }

            // 正式送出表單
            document.getElementById('hidden-form').submit();
            
            // 彈出提示（因為 submit 會換頁，這只是保險）
            setTimeout(() => {
                alert('回覆成功！特派員小秋出發回報囉！✅');
            }, 500);
        }
    </script>
</body>
</html>
